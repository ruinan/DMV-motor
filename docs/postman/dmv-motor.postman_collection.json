    {
      "name": "Practice",
      "item": [
        {
          "name": "POST /api/v1/practice/sessions  (Start session)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entry_type\": \"free_trial\",\n  \"language\": \"en\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/practice/sessions",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "practice", "sessions" ]
            },
            "description": "entry_type: 'free_trial' (anonymous OK) or 'full' (requires active access pass). Captures session_id + first question_id/variant_id."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.success && r.data) {",
                  "    pm.collectionVariables.set('sessionId', r.data.session_id);",
                  "    if (r.data.next_question) {",
                  "        pm.collectionVariables.set('questionId', r.data.next_question.question_id);",
                  "        pm.collectionVariables.set('variantId', r.data.next_question.variant_id);",
                  "    }",
                  "    console.log('sessionId=' + r.data.session_id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/v1/practice/sessions/:id/next-question",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/practice/sessions/{{sessionId}}/next-question",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "practice", "sessions", "{{sessionId}}", "next-question" ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.success && r.data && r.data.question_id) {",
                  "    pm.collectionVariables.set('questionId', r.data.question_id);",
                  "    pm.collectionVariables.set('variantId', r.data.variant_id);",
                  "}"
                ]
              }
            }
          ]
