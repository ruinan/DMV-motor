decision.content.personalized_generation=allow_generate_new_targeted_questions_based_on_user_weakness
decision.review.mistake_record_creation=create_or_update_on_each_wrong_answer
decision.review.mistake_record_granularity=question_level
decision.review.mistake_record_attach=main_topic
decision.review.mistake_record_topic_logic=derived_in_review_and_readiness_engine_not_second_source_of_truth
decision.review.mistake_record_deactivation=not_after_single_correct_answer
decision.review.mistake_record_deactivation_rule=deactivate_after_related_review_completed_and_sustained_correct_performance
decision.review.mistake_record_reactivation=reactivate_or_update_on_new_wrong_answer
decision.review.mistake_record_formula_status=defer_algorithm_keep_rule_level_definition_now
decision.review.review_task_generation_triggers=wrong_in_practice|wrong_in_mock|critical_topic_undercovered|active_mistake_record_stale_unresolved|mock_exposed_readiness_blocking_weakness
decision.review.review_task_priority_dimensions=risk_level|readiness_impact|foundation_gap|mistake_persistence|recency|mock_signal|coverage_gap|staleness
decision.review.review_task_priority_order=high_risk_and_readiness_impact|foundation_gap|mock_exposed_weakness|persistent_or_stale_errors|general_coverage_gap
decision.review.review_pack_role=execution_slice_from_review_task_pool
decision.review.review_pack_convergence=take_highest_value_tasks_within_capacity_not_all_active_tasks
decision.review.review_pack_when_too_many=keep_excess_in_task_pool_for_later_rounds
decision.review.review_pack_when_too_few=fill_with_critical_coverage|light_consolidation|pre_readiness_validation
decision.review.review_pack_constraints=foundation_before_fine_grained|avoid_single_topic_domination|include_some_mastery_validation|allow_resume_and_partial_refresh
