rules.interrupt=practice_resume|review_resume|mock_exit_warn_then_end_no_resume
rules.progress=reset_learning_progress_yes|clear_history_no
rules.access=30d_pass|practice_unlimited|review_unlimited|mock_limited_count_tbd
rules.business=free_trial_plus_30d_paid|no_ads
rules.language=en_zh_only|same_learning_system_cross_language
rules.reminder=backend_generates_tasks|channel_depends_on_client|state_based
rules.scoring=real_score_not_faked|high_score!=ready
rules.readiness=depends_on_score+topic_coverage+hard_topics+review_completion
rules.speed=recommended_pace_levels=slow|ok|fast
rules.export=memory_progress_export_yes|encrypted|current_device_read_only_default

