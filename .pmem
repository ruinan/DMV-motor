decision.content.question_model=shared_question_bank_with_personalized_delivery
decision.content.personalization_basis=mistake_record|review_state|user_learning_state
decision.content.personalized_generation=allow_generate_new_targeted_questions_based_on_user_weakness
decision.review.mistake_record_creation=create_or_update_on_each_wrong_answer
decision.review.mistake_record_granularity=question_level
decision.review.mistake_record_attach=main_topic
decision.review.mistake_record_topic_logic=derived_in_review_and_readiness_engine_not_second_source_of_truth
decision.review.mistake_record_deactivation=not_after_single_correct_answer
decision.review.mistake_record_deactivation_rule=deactivate_when_mastery_params_met(80pct_accuracy+last8q_6correct+no_consecutive_same_confusion_point)
decision.review.mistake_record_reactivation=reactivate_or_update_on_new_wrong_answer
decision.review.review_task_generation_triggers=wrong_in_practice|wrong_in_mock|critical_topic_undercovered|active_mistake_record_stale_unresolved|mock_exposed_readiness_blocking_weakness
decision.review.review_task_priority_dimensions=risk_level|readiness_impact|foundation_gap|mistake_persistence|recency|mock_signal|coverage_gap|staleness
decision.review.review_task_priority_order=high_risk_and_readiness_impact|foundation_gap|mock_exposed_weakness|persistent_or_stale_errors|general_coverage_gap
decision.review.review_pack_role=execution_slice_from_review_task_pool
decision.review.review_pack_convergence=take_highest_value_tasks_within_capacity_not_all_active_tasks
decision.review.review_pack_task_count_default=8
decision.review.review_pack_question_count_default=20
decision.review.review_pack_capacity_note=task_count(8)_and_question_count(20)_are_independent_params|8tasks_x_2to4q_each_matches_20q_target
decision.review.review_pack_language=snapshot_user_preference_at_generation_time|mid_pack_language_change_takes_effect_next_pack
decision.review.review_pack_when_too_many=keep_excess_in_task_pool_for_later_rounds
decision.review.review_pack_when_too_few=fill_with_critical_coverage|light_consolidation|pre_readiness_validation
decision.review.review_pack_constraints=foundation_before_fine_grained|avoid_single_topic_domination|include_some_mastery_validation|allow_resume_and_partial_refresh
decision.review.completion_before_readiness=true
decision.review.completion_readiness_relation=completion_first_then_readiness_built_on_top
decision.review.completion_model=coverage_plus_initial_mastery
decision.review.completion_metrics=coverage_completion|mastery_status
decision.review.readiness_hard_gates=minimum_mock_score|critical_topic_coverage_not_missing|high_risk_active_weakness_not_excessive|critical_review_tasks_not_largely_unfinished|performance_stability_required
decision.review.readiness_target=p90_worst_case_should_still_be_likely_to_pass_real_exam
decision.review.readiness_thresholds_status=parameterized_in_parameters.md
decision.review.mock_feedback_loop=mock_errors_write_results_then_update_mistake_records_then_raise_high_priority_review_tasks_then_refresh_summary_and_review_pack
decision.review.mock_error_weight=high
decision.review.mock_with_existing_mistake_record=boost_review_intensity
decision.review.good_mock_result_effect=lower_priority_for_easy_or_resolved_error_prone_items_not_clear_review_pool
decision.mock.exit_rule=quota_consumed|no_resume|partial_answers_uploaded_on_exit|unanswered_not_recorded
decision.mock.quota_deduction_timing=on_successful_start
decision.mock.count_per_30d_pass=5
decision.mock.answer_submission=bulk_at_end_for_submit|partial_bulk_on_exit
