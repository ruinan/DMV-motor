scope.core=practice|mistakes|review|mock_exam
scope.support=login|summary|reminder|ai_explain|ai_recommend|memory_export
scope.not=community|leaderboard|video|multi_state|complex_agent|voice_coach|behavior_analysis|content_platform|full_safety_education

rules.users=all_CA_M1_candidates_no_prior-learning-assumption
rules.learning=coarse_to_fine;base_concepts>rule_details>similar_rule_disambiguation>scenario_judgment
rules.interrupt=practice_resume|review_resume|mock_exit_warn_then_end_no_resume|mock_exit_partial_answers_uploaded
rules.progress=reset_learning_progress_yes|clear_history_no
rules.access=30d_pass|practice_unlimited|review_unlimited|mock_5_per_pass
rules.business=free_trial_plus_30d_paid|no_ads
rules.language=en_zh_only|same_learning_system_cross_language
rules.reminder=backend_generates_tasks|channel_depends_on_client|state_based|max_1_per_day|cooldown_between_same_type|stop_after_3_consecutive_ignored
rules.scoring=real_score_not_faked|high_score!=ready
rules.readiness=depends_on_score+topic_coverage+hard_topics+review_completion
rules.speed=recommended_pace_levels=slow|ok|fast
rules.export=memory_progress_export_yes|encrypted|current_device_read_only_default
rules.free_trial=fixed_30q_set|anonymous_and_registered_can_access|replayable|no_countdown_counter

undef=device_binding_migration_details|price_amount|refund_policy|extra_mock_purchase_rule|exact_reminder_times|question_level_mastery_model

next=start_mvp_implementation|phase1_content_and_data_layer
later=phase2_auth_access|phase3_practice|phase4_review_readiness|phase5_mock|phase6_ai_reminder_export

read_order=.pmem>README.md>relevant docs/*.md
doc_authority=development/api-contract.md>api.md|runtime-parameters.md>parameters.md(reminder)|parameters.md(free_trial,review,mastery,readiness)

