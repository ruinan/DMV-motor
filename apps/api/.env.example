# Local dev environment overrides for Spring Boot.
# Copy to apps/api/.env (gitignored) and fill in real values when running locally.
# Production reads these from Cloud Run env vars (Terraform-managed) — see infra/terraform/cloudrun.tf.

# AI explain endpoint — switch from the dev/test stub to DeepSeek by setting:
#   APP_AI_PROVIDER=deepseek
# and supplying a key. Leave APP_AI_PROVIDER unset (or =stub) to keep using
# StubAiExplanationProvider, which needs no key.
APP_AI_PROVIDER=stub
APP_AI_DEEPSEEK_API_KEY=

# Firebase Auth — set to "true" only if you want to test the production
# verifier path locally against the Firebase Auth emulator. Default (unset
# or "false") uses StubFirebaseVerifier so `Authorization: Bearer <numericId>`
# works for IT and Postman.
# APP_AUTH_FIREBASE_ENABLED=false
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# GOOGLE_CLOUD_PROJECT=demo-dmv-motor
