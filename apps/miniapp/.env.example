# Copy to .env.development / .env.production and fill in. Taro exposes vars
# prefixed TARO_APP_ to process.env at build time. None of these are secrets —
# the Firebase Web API key is a public client identifier, like on the web app.

# Backend base URL. Local dev: the local Spring Boot (toggle "do not verify
# request domains" in WeChat DevTools). Prod: the Cloud Run URL.
TARO_APP_API_BASE=http://localhost:8080

# Firebase Web API key (public) — used for the Auth REST custom-token exchange.
TARO_APP_FIREBASE_API_KEY=
